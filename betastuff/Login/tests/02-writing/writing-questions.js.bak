// ✅ RANDOM QUESTION SELECTION FUNCTION
// Loads one random set from each part

function loadRandomQuestions() {
    const questionSet = {};
    
    // Part 1: Random word-level writing set
    const part1Sets = WRITING_QUESTION_BANK.part1.questionSets;
    const randomPart1Index = Math.floor(Math.random() * part1Sets.length);
    questionSet.part1 = {
        ...WRITING_QUESTION_BANK.part1,
        messages: part1Sets[randomPart1Index].messages
    };
    delete questionSet.part1.questionSets;
    
    // Part 2: Random short text set
    const part2Sets = WRITING_QUESTION_BANK.part2.questionSets;
    const randomPart2Index = Math.floor(Math.random() * part2Sets.length);
    const part2Selected = part2Sets[randomPart2Index];
    questionSet.part2 = {
        ...WRITING_QUESTION_BANK.part2,
        ...part2Selected
    };
    delete questionSet.part2.questionSets;
    
    // Part 3: Random social media responses set
    const part3Sets = WRITING_QUESTION_BANK.part3.questionSets;
    const randomPart3Index = Math.floor(Math.random() * part3Sets.length);
    questionSet.part3 = {
        ...WRITING_QUESTION_BANK.part3,
        questions: part3Sets[randomPart3Index].questions
    };
    delete questionSet.part3.questionSets;
    
    // Part 4: Random email scenario
    const part4Scenarios = WRITING_QUESTION_BANK.part4.scenarios;
    const randomPart4Index = Math.floor(Math.random() * part4Scenarios.length);
    questionSet.part4 = {
        ...WRITING_QUESTION_BANK.part4,
        ...part4Scenarios[randomPart4Index]
    };
    delete questionSet.part4.scenarios;
    
    return questionSet;
}

// ✅ UTILITY FUNCTIONS

function countWords(text) {
    if (!text || text.trim() === '') return 0;
    return text.trim().split(/\s+/).length;
}

function countCharacters(text) {
    if (!text) return 0;
    return text.length;
}

function formatText(command, value = null) {
    document.execCommand(command, false, value);
}

// Export for use in main script
if (typeof module !== 'undefined' && module.exports) {
    module.exports = { WRITING_QUESTION_BANK, loadRandomQuestions, countWords, countCharacters, formatText };
}
